# Внешний IP/домен вашего сервера (для tg://proxy ссылки)
PUBLIC_HOST=your.server.ip.or.domain

# Параметры запуска mtg simple-run (рабочий вариант)
# -n: маскирующий хост (можно использовать 1.1.1.1 или домен)
MTG_FAKE_TLS_HOST=1.1.1.1
# -i: режим выбора IP
MTG_IP_MODE=prefer-ipv4

# Секрет (hex) из команды:
# docker run --rm nineseconds/mtg:2 generate-secret --hex ru.wikipedia.org
MTG_SECRET=ee8015f0d7392e375f8b176be6b6df164b72752e77696b6970656469612e6f7267

# Внутренний порт mtg в docker-сети (gateway подключается сюда)
MTG_UPSTREAM_PORT=443

# Диапазон внешних портов для пользователей
PORT_RANGE_START=11000
PORT_RANGE_END=11020

# Порт web-admin
ADMIN_PORT=8000

# Частота обновления активных портов gateway
GATEWAY_POLL_INTERVAL=2.0

# Принудительно разрывать сессии старше N секунд (таймер для авто-отключения в TG)
GATEWAY_CLIENT_MAX_AGE=0
# Частота запуска проверки TTL сессий
GATEWAY_ENFORCE_INTERVAL=5
