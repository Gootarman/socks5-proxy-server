# Внешний IP/домен вашего сервера (для tg://proxy ссылки)
PUBLIC_HOST=your.server.ip.or.domain

# Домен для FakeTLS в mtg (пример: ru.wikipedia.org)
MTG_FAKE_TLS_DOMAIN=ru.wikipedia.org

# Секрет должен быть сгенерирован командой:
# docker run --rm nineseconds/mtg:2 generate-secret --hex ${MTG_FAKE_TLS_DOMAIN}
MTG_SECRET=dd000000000000000000000000000000

MTG_UPSTREAM_PORT=3128
PORT_RANGE_START=11000
PORT_RANGE_END=11020
ADMIN_PORT=8000
GATEWAY_POLL_INTERVAL=2.0
